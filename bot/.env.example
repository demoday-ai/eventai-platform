# bot service .env example for demoday-core monorepo (031-bot-replacement).
# Copy to bot/.env and fill in BOT_TOKEN + OPENROUTER_API_KEY.

# === REQUIRED ===
BOT_TOKEN=                              # Telegram bot token from @BotFather (same as backend)
OPENROUTER_API_KEY=                     # OpenRouter API key (sk-or-...) — standalone LLM mode

# === DEFAULTS (work with monorepo docker-compose) ===
BOT_MODE=polling
LLM_MODEL=deepseek/deepseek-v3.2
EMBEDDING_MODEL=google/gemini-embedding-001
ORGANIZER_CHAT_ID=0                     # Telegram group ID for support forwarding

# === GITHUB (optional, for repo analysis) ===
GITHUB_TOKEN=

# === INFRASTRUCTURE (shared with backend) ===
# Note: db service in demoday-core docker-compose uses postgres user "demoday"
DATABASE_URL=postgresql+asyncpg://demoday:demoday@db:5432/demoday
REDIS_URL=redis://redis:6379/1          # db1 dedicated to bot FSM (db0 reserved for backend/celery)
REDIS_PASSWORD=

# === LLM PLATFORM MODE (Phase 5, optional) ===
# When MASTER_TOKEN is set, bot registers with llm-agent-platform proxy.
# All LLM calls go through platform: metrics (Prometheus), tracing (Langfuse), circuit breaker.
# PLATFORM_URL=http://platform-app:8000
# MASTER_TOKEN=
